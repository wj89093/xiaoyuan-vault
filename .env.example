# 晓园 Vault AI 配置
# 支持多 provider，系统自动选择（默认 DeepSeek，便宜）

# DeepSeek V4（默认，便宜 + 强推理）
DEEPSEEK_API_KEY=your_deepseek_key_here

# 阿里通义千问（备用）
QWEN_API_KEY=your_qwen_key_here
QWEN_MODEL=qwen3.6-flash

# MiniMax（扩展用，可不填）
MINIMAX_API_KEY=your_minimax_key_here

# ─── 使用逻辑 ─────────────────────────────
# 默认用 DeepSeek V4（最便宜 + 强推理）
# DeepSeek 失败 → 自动切换 Qwen
# Qwen 失败 → 返回错误
#
# 如只配了一个 key，系统只用那一个
