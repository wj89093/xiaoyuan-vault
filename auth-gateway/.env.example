# 晓园 Auth Gateway 配置

# JWT 密钥（生产环境必改）
JWT_SECRET=xiaoyuan-jwt-secret-change-in-production

# 服务端口
PORT=3000

# 管理员密码（生产环境必改）
ADMIN_PASSWORD=xiaoyuan-admin-2026

# ─── AI 配置 ─────────────────────────────
# DeepSeek V4 Flash（默认，便宜 ¥1/M 输入）
# 如果不配置 DEEPSEEK_API_KEY，自动 fallback 到 QWEN_API_KEY
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# Qwen 备用（DEEPSEEK_API_KEY 未配置时使用）
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen3.6-flash

# ─── OAuth（可选）──────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:3000/auth/feishu/callback

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/auth/wechat/callback

# ─── 邮件配置（可选）──────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
